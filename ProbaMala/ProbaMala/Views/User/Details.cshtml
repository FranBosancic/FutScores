@model User

@{
    ViewData["Title"] = "User Details - Match Center";
}

<section class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-slate-400">
        <a asp-controller="Home" asp-action="Index" class="font-medium text-lime-300 transition hover:text-lime-200">Home</a>
        <span class="px-2 text-slate-600">/</span>
        <a asp-controller="User" asp-action="Index" class="font-medium text-lime-300 transition hover:text-lime-200">Users</a>
        <span class="px-2 text-slate-600">/</span>
        <span>@Model.FirstName @Model.LastName</span>
    </nav>

    <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
        <div>
            <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">User Profile</span>
            <h2 class="mt-2 font-['Oswald'] text-4xl leading-none text-white">@Model.FirstName @Model.LastName</h2>
            <p class="mt-3 text-sm text-slate-400">User profile and rating activity context</p>
        </div>
    </section>

    <section class="grid gap-8 xl:grid-cols-2">
        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">User Information</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Identity details</h2>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-1">
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">First Name</div>
                    <strong class="mt-3 block text-lg text-white">@Model.FirstName</strong>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Last Name</div>
                    <strong class="mt-3 block text-lg text-white">@Model.LastName</strong>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 sm:col-span-2 xl:col-span-1">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Email Address</div>
                    <strong class="mt-3 block break-all text-lg text-lime-300">@Model.Email</strong>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 sm:col-span-2 xl:col-span-1">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">User ID</div>
                    <strong class="mt-3 block text-lg text-white">#@Model.Id</strong>
                </article>
            </div>
        </section>

        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Profile Activity</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Current actions</h2>
            </div>

            <div class="grid gap-4">
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">View Ratings</div>
                    <a asp-controller="Rating" asp-action="Index" class="mt-3 block text-lg font-semibold text-lime-300 transition hover:text-lime-200">Browse all ratings</a>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Account Status</div>
                    <span class="mt-3 inline-flex rounded-full border border-emerald-400/20 bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-200">Active</span>
                </article>
            </div>
        </section>
    </section>

    <div>
        <a asp-controller="User" asp-action="Index" class="text-sm font-medium text-lime-300 transition hover:text-lime-200">Back to all users</a>
    </div>
</section>
