@model User

@{
    ViewData["Title"] = "User Details";
}

<div class="bg-slate-900 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Breadcrumb -->
        <nav class="mb-6">
            <a asp-controller="Home" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 transition-colors">Home</a>
            <span class="text-slate-500 mx-2">›</span>
            <a asp-controller="User" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 transition-colors">Users</a>
            <span class="text-slate-500 mx-2">›</span>
            <span class="text-slate-300">@Model.FirstName @Model.LastName</span>
        </nav>

        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-slate-50 mb-2">@Model.FirstName @Model.LastName</h1>
            <p class="text-slate-300 text-lg">User Profile</p>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <!-- User Information Card -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                <h2 class="text-2xl font-semibold text-slate-50 mb-6">User Information</h2>

                <div class="space-y-4">
                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">First Name</p>
                        <p class="text-slate-50 font-medium">@Model.FirstName</p>
                    </div>

                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Last Name</p>
                        <p class="text-slate-50 font-medium">@Model.LastName</p>
                    </div>

                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Email Address</p>
                        <p class="text-emerald-400 font-medium break-all hover:text-emerald-300 transition-colors cursor-pointer">@Model.Email</p>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-1">User ID</p>
                        <p class="text-slate-50 font-medium">#@Model.Id</p>
                    </div>
                </div>
            </div>

            <!-- Profile Stats Card -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                <h2 class="text-2xl font-semibold text-slate-50 mb-6">Profile Activity</h2>

                <div class="space-y-4">
                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-2">View Ratings</p>
                        <a asp-controller="Rating" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 font-medium transition-colors">Browse all ratings →</a>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-2">Account Status</p>
                        <span class="bg-emerald-500 text-white text-xs font-bold px-3 py-1 rounded-full">Active</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-8">
            <a asp-controller="User" asp-action="Index" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2 rounded-md transition-colors font-medium inline-block">← Back to Users</a>
        </div>
    </div>
</div>
