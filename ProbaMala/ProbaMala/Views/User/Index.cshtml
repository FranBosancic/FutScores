@model List<User>

@{
    ViewData["Title"] = "Users";
}

<h1>Users</h1>

<table border="1" cellpadding="10" cellspacing="0">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FirstName</td>
                <td>@user.LastName</td>
                <td>@user.Email</td>
                <td><a href="@Url.Action("Details", "User", new { id = user.Id })">View</a></td>
            </tr>
        }
    </tbody>
</table>
