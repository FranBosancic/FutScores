@model ClubDetailsViewModel

@{
    ViewData["Title"] = "Club Details - Match Center";
}

<section class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-slate-400">
        <a asp-controller="Home" asp-action="Index" class="font-medium text-lime-300 transition hover:text-lime-200">Home</a>
        <span class="px-2 text-slate-600">/</span>
        <a asp-controller="Club" asp-action="Index" class="font-medium text-lime-300 transition hover:text-lime-200">Clubs</a>
        <span class="px-2 text-slate-600">/</span>
        <span>@Model.Name</span>
    </nav>

    <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Club Focus</span>
                <h2 class="mt-2 font-['Oswald'] text-4xl leading-none text-white">@Model.Name</h2>
                <p class="mt-3 text-sm text-slate-400">Competing in @Model.LeagueName since @Model.FoundedDate.Year</p>
            </div>
            <span class="inline-flex h-12 min-w-[3rem] items-center justify-center rounded-full bg-amber-400/15 px-4 font-['Oswald'] text-xl text-amber-200">@Model.FoundedDate.Year</span>
        </div>
    </section>

    <section class="grid gap-8 xl:grid-cols-2">
        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Club Information</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Identity and timeline</h2>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-1">
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Club Name</div>
                    <strong class="mt-3 block text-lg text-white">@Model.Name</strong>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Founded</div>
                    <strong class="mt-3 block text-lg text-white">@Model.FoundedDate.ToString("MMMM dd, yyyy")</strong>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 sm:col-span-2 xl:col-span-1">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">League</div>
                    <a asp-controller="League" asp-action="Details" asp-route-id="@Model.LeagueId" class="mt-3 block text-lg font-semibold text-lime-300 transition hover:text-lime-200">@Model.LeagueName</a>
                </article>
            </div>
        </section>

        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Related Entity</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">League-first navigation</h2>
            </div>

            <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h3 class="text-xl font-semibold text-white">@Model.LeagueName</h3>
                        <p class="mt-1 text-sm text-slate-400">Competition context</p>
                    </div>
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-200">League</span>
                </div>
                <div class="mt-4 grid gap-2 text-sm text-slate-300">
                    <span>Club: @Model.Name</span>
                    <span>Founded: @Model.FoundedDate.Year</span>
                </div>
                <div class="mt-5 flex flex-wrap gap-4 text-sm font-medium">
                    <a asp-controller="League" asp-action="Details" asp-route-id="@Model.LeagueId" class="text-lime-300 transition hover:text-lime-200">Open league</a>
                    <a asp-controller="Club" asp-action="Index" class="text-lime-300 transition hover:text-lime-200">More clubs</a>
                </div>
            </article>
        </section>
    </section>

    <div>
        <a asp-controller="Club" asp-action="Index" class="text-sm font-medium text-lime-300 transition hover:text-lime-200">Back to all clubs</a>
    </div>
</section>
