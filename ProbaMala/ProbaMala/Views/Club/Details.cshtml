@model ClubDetailsViewModel

@{
    ViewData["Title"] = "Club Details";
}

<h1>@Model.Name</h1>

<div>
    <p><strong>Founded:</strong> @Model.FoundedDate.ToString("yyyy-MM-dd")</p>
    <p><strong>League:</strong> @Model.LeagueName</p>
</div>

<p><a href="@Url.Action("Index", "Club")">Back to Clubs</a></p>
