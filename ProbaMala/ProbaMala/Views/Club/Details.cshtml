@model ClubDetailsViewModel

@{
    ViewData["Title"] = "Club Details - Match Center";
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <nav class="fs-match-kickoff">
            <a asp-controller="Home" asp-action="Index" class="fs-card-link">Home</a>
            <span> / </span>
            <a asp-controller="Club" asp-action="Index" class="fs-card-link">Clubs</a>
            <span> / </span>
            <span>@Model.Name</span>
        </nav>

        <section class="fs-section">
            <div class="fs-entity-hero">
                <div>
                    <span class="fs-section-kicker">Club Focus</span>
                    <h2>@Model.Name</h2>
                    <p class="fs-match-kickoff">Competing in @Model.LeagueName since @Model.FoundedDate.Year</p>
                </div>
                <span class="fs-rating-pill">@Model.FoundedDate.Year</span>
            </div>
        </section>

        <section class="fs-section fs-two-column">
            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">Club Information</span>
                        <h2>Identity and timeline</h2>
                    </div>
                </div>

                <div class="fs-detail-panel-grid">
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Club Name</span>
                        <strong>@Model.Name</strong>
                    </article>
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Founded</span>
                        <strong>@Model.FoundedDate.ToString("MMMM dd, yyyy")</strong>
                    </article>
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">League</span>
                        <a asp-controller="League" asp-action="Details" asp-route-id="@Model.LeagueId" class="fs-card-link">@Model.LeagueName</a>
                    </article>
                </div>
            </div>

            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">Related Entity</span>
                        <h2>League-first navigation</h2>
                    </div>
                </div>

                <div class="fs-player-card fs-player-card--entity">
                    <div class="fs-player-card-top">
                        <div>
                            <h3>@Model.LeagueName</h3>
                            <p>Competition context</p>
                        </div>
                        <span class="fs-tone-pill fs-tone-pill--neutral">League</span>
                    </div>
                    <div class="fs-player-meta fs-player-meta--stacked">
                        <span>Club: @Model.Name</span>
                        <span>Founded: @Model.FoundedDate.Year</span>
                    </div>
                    <div class="fs-entity-links">
                        <a asp-controller="League" asp-action="Details" asp-route-id="@Model.LeagueId" class="fs-card-link">Open league</a>
                        <a asp-controller="Club" asp-action="Index" class="fs-card-link">More clubs</a>
                    </div>
                </div>
            </div>
        </section>

        <div>
            <a asp-controller="Club" asp-action="Index" class="fs-card-link">Back to all clubs</a>
        </div>
    </div>
</section>
