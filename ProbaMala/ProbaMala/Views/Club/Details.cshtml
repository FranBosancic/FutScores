@model ClubDetailsViewModel

@{
    ViewData["Title"] = "Club Details";
}

<div class="bg-slate-900 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Breadcrumb -->
        <nav class="mb-6">
            <a asp-controller="Home" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 transition-colors">Home</a>
            <span class="text-slate-500 mx-2">›</span>
            <a asp-controller="Club" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 transition-colors">Clubs</a>
            <span class="text-slate-500 mx-2">›</span>
            <span class="text-slate-300">@Model.Name</span>
        </nav>

        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-slate-50 mb-2">@Model.Name</h1>
            <p class="text-slate-300 text-lg">Founded in @Model.FoundedDate.Year</p>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <!-- Club Information Card -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                <h2 class="text-2xl font-semibold text-slate-50 mb-6">Club Information</h2>

                <div class="space-y-4">
                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Club Name</p>
                        <p class="text-slate-50 font-medium">@Model.Name</p>
                    </div>

                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Founded</p>
                        <p class="text-slate-50 font-medium">@Model.FoundedDate.ToString("MMMM dd, yyyy")</p>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-1">League</p>
                        <p class="text-emerald-400 font-medium hover:text-emerald-300 transition-colors cursor-pointer">@Model.LeagueName</p>
                    </div>
                </div>
            </div>

            <!-- League Information Card -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                <h2 class="text-2xl font-semibold text-slate-50 mb-6">League Details</h2>

                <div class="space-y-4">
                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">League Name</p>
                        <p class="text-slate-50 font-medium">@Model.LeagueName</p>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-2">Navigate to League</p>
                        <a asp-controller="League" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 font-medium transition-colors">View all leagues →</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-8">
            <a asp-controller="Club" asp-action="Index" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2 rounded-md transition-colors font-medium inline-block">← Back to Clubs</a>
        </div>
    </div>
</div>
