@model List<ClubDetailsViewModel>

@{
    ViewData["Title"] = "Clubs - Match Center";
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <section class="fs-section">
            <div class="fs-section-heading">
                <div>
                    <span class="fs-section-kicker">Clubs</span>
                    <h2>Club hubs that connect league and player browsing</h2>
                </div>
                <span class="fs-match-kickoff">@Model.Count club@(Model.Count != 1 ? "s" : string.Empty) active in the board</span>
            </div>

            <div class="fs-player-grid fs-player-grid--wide">
                @foreach (var club in Model)
                {
                    <article class="fs-player-card fs-player-card--entity">
                        <div class="fs-player-card-top">
                            <div>
                                <h3>@club.Name</h3>
                                <p>@club.LeagueName</p>
                            </div>
                            <span class="fs-rating-pill">@club.FoundedDate.Year</span>
                        </div>

                        <div class="fs-player-meta fs-player-meta--stacked">
                            <span>Founded: @club.FoundedDate.ToString("MMM dd, yyyy")</span>
                            <span>League: @club.LeagueName</span>
                        </div>

                        <div class="fs-entity-links">
                            <a asp-controller="League" asp-action="Details" asp-route-id="@club.LeagueId" class="fs-card-link">Open league</a>
                            <a asp-controller="Club" asp-action="Details" asp-route-id="@club.Id" class="fs-card-link">Open club</a>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
</section>
