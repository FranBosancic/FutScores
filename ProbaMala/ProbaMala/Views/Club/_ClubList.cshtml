@model List<ClubDetailsViewModel>

<div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
        <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Clubs</span>
        <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Club hubs that connect league and player browsing</h2>
    </div>
    <div class="flex flex-col items-start gap-3 sm:items-end">
        <span class="text-sm text-slate-400">@Model.Count club@(Model.Count != 1 ? "s" : string.Empty) active in the board</span>
        <a asp-route="club-create" class="inline-flex items-center rounded-full bg-lime-400 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-lime-300">Add club</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="mt-6 rounded-[1.5rem] border border-dashed border-white/10 bg-white/5 px-5 py-8 text-center text-slate-300">
        No clubs match the current search.
    </div>
}
else
{
    <div class="mt-6 grid gap-4 lg:grid-cols-2 xl:grid-cols-3">
        @foreach (var club in Model)
        {
            <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h3 class="text-xl font-semibold text-white">@club.Name</h3>
                        <p class="mt-1 text-sm text-slate-400">@club.LeagueName</p>
                    </div>
                    <span class="inline-flex h-11 min-w-[2.75rem] items-center justify-center rounded-full bg-amber-400/15 px-3 font-['Oswald'] text-xl text-amber-200">@club.FoundedDate.Year</span>
                </div>

                <div class="mt-4 grid gap-2 text-sm text-slate-300">
                    <span>Founded: @club.FoundedDate.ToString("MMM dd, yyyy")</span>
                    <span>Players: @club.PlayerCount</span>
                    <span>Matches: @club.MatchCount</span>
                </div>

                <div class="mt-5 flex flex-wrap gap-4 text-sm font-medium">
                    <a asp-route="league-details" asp-route-id="@club.LeagueId" class="text-lime-300 transition hover:text-lime-200">Open league</a>
                    <a asp-route="club-details" asp-route-id="@club.Id" class="text-lime-300 transition hover:text-lime-200">Open club</a>
                    <a asp-route="club-edit" asp-route-id="@club.Id" class="text-lime-300 transition hover:text-lime-200">Edit</a>
                    <a asp-route="club-delete" asp-route-id="@club.Id" class="text-rose-300 transition hover:text-rose-200">Delete</a>
                </div>
            </article>
        }
    </div>
}