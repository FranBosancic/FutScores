@model ProbaMala.Models.HomeViewModel
@{
    ViewData["Title"] = "FutScores – Dashboard";
}

<div class="bg-slate-900 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

        <!-- Hero -->
        <div class="mb-10">
            <h1 class="text-4xl font-bold text-slate-50 mb-2">FutScores Dashboard</h1>
            <p class="text-slate-400 text-lg">Live stats, club form, and match ratings — all in one place.</p>
        </div>

        <!-- Stat Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6 flex flex-col gap-2">
                <span class="text-slate-400 text-sm uppercase tracking-widest">Clubs</span>
                <span class="text-4xl font-bold text-emerald-400">@Model.TotalClubs</span>
                <a asp-controller="Club" asp-action="Index" class="text-slate-500 text-xs hover:text-emerald-400 transition-colors mt-1">View all →</a>
            </div>
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6 flex flex-col gap-2">
                <span class="text-slate-400 text-sm uppercase tracking-widest">Players</span>
                <span class="text-4xl font-bold text-emerald-400">@Model.TotalPlayers</span>
                <a asp-controller="Player" asp-action="Index" class="text-slate-500 text-xs hover:text-emerald-400 transition-colors mt-1">View all →</a>
            </div>
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6 flex flex-col gap-2">
                <span class="text-slate-400 text-sm uppercase tracking-widest">Matches</span>
                <span class="text-4xl font-bold text-emerald-400">@Model.TotalMatches</span>
                <a asp-controller="Match" asp-action="Index" class="text-slate-500 text-xs hover:text-emerald-400 transition-colors mt-1">View all →</a>
            </div>
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6 flex flex-col gap-2">
                <span class="text-slate-400 text-sm uppercase tracking-widest">Avg Rating</span>
                <span class="text-4xl font-bold text-amber-400">@Model.AverageRating</span>
                <a asp-controller="Rating" asp-action="Index" class="text-slate-500 text-xs hover:text-emerald-400 transition-colors mt-1">View all →</a>
            </div>
        </div>

        <!-- Club Form Table -->
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
            <h2 class="text-2xl font-semibold text-slate-50 mb-1">Club Form</h2>
            <p class="text-slate-500 text-sm mb-6">Last 5 results per club — most recent on the right</p>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-slate-700">
                            <th class="text-left text-slate-400 text-xs uppercase tracking-widest pb-3 pr-6">Club</th>
                            <th class="text-left text-slate-400 text-xs uppercase tracking-widest pb-3">Form</th>
                            <th class="text-right text-slate-400 text-xs uppercase tracking-widest pb-3 pl-6">Record</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.ClubForms)
                        {
                            var wins = entry.Results.Count(r => r == "W");
                            var draws = entry.Results.Count(r => r == "D");
                            var losses = entry.Results.Count(r => r == "L");

                            <tr class="border-b border-slate-700/50 hover:bg-slate-700/30 transition-colors">
                                <td class="py-4 pr-6">
                                    <span class="text-slate-100 font-medium">@entry.ClubName</span>
                                </td>
                                <td class="py-4">
                                    <div class="flex gap-1.5 items-center">
                                        @foreach (var result in entry.Results)
                                        {
                                            if (result == "W")
                                            {
                                                <span class="w-7 h-7 rounded-full bg-emerald-500 flex items-center justify-center text-white text-xs font-bold" title="Win">W</span>
                                            }
                                            else if (result == "D")
                                            {
                                                <span class="w-7 h-7 rounded-full bg-amber-500 flex items-center justify-center text-white text-xs font-bold" title="Draw">D</span>
                                            }
                                            else
                                            {
                                                <span class="w-7 h-7 rounded-full bg-red-500 flex items-center justify-center text-white text-xs font-bold" title="Loss">L</span>
                                            }
                                        }
                                        @if (!entry.Results.Any())
                                        {
                                            <span class="text-slate-600 text-sm italic">No matches</span>
                                        }
                                    </div>
                                </td>
                                <td class="py-4 pl-6 text-right">
                                    <span class="text-emerald-400 font-semibold">@wins</span>
                                    <span class="text-slate-600 mx-1">/</span>
                                    <span class="text-amber-400 font-semibold">@draws</span>
                                    <span class="text-slate-600 mx-1">/</span>
                                    <span class="text-red-400 font-semibold">@losses</span>
                                    <span class="text-slate-600 text-xs ml-2">W/D/L</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Legend -->
            <div class="flex gap-4 mt-5 pt-4 border-t border-slate-700">
                <div class="flex items-center gap-1.5">
                    <span class="w-3 h-3 rounded-full bg-emerald-500 inline-block"></span>
                    <span class="text-slate-400 text-xs">Win</span>
                </div>
                <div class="flex items-center gap-1.5">
                    <span class="w-3 h-3 rounded-full bg-amber-500 inline-block"></span>
                    <span class="text-slate-400 text-xs">Draw</span>
                </div>
                <div class="flex items-center gap-1.5">
                    <span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span>
                    <span class="text-slate-400 text-xs">Loss</span>
                </div>
            </div>
        </div>

    </div>
</div>