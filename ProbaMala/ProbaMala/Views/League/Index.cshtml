@model List<League>

@{
    ViewData["Title"] = "Leagues - Match Center";
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <section class="fs-section">
            <div class="fs-section-heading">
                <div>
                    <span class="fs-section-kicker">Leagues</span>
                    <h2>Competition hubs for club and match browsing</h2>
                </div>
                <span class="fs-match-kickoff">@Model.Count league@(Model.Count != 1 ? "s" : string.Empty) available</span>
            </div>

            <div class="fs-player-grid fs-player-grid--wide">
                @foreach (var league in Model)
                {
                    <article class="fs-player-card fs-player-card--entity">
                        <div class="fs-player-card-top">
                            <div>
                                <h3>@league.Name</h3>
                                <p>Competition overview</p>
                            </div>
                            <span class="fs-tone-pill fs-tone-pill--neutral">League</span>
                        </div>

                        <div class="fs-player-meta fs-player-meta--stacked">
                            <span>Competition ID: #@league.Id</span>
                            <span>Use this page as the hub for clubs and matches</span>
                        </div>

                        <div class="fs-entity-links">
                            <a asp-controller="Match" asp-action="Index" class="fs-card-link">Open matches</a>
                            <a asp-controller="League" asp-action="Details" asp-route-id="@league.Id" class="fs-card-link">Open league</a>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
</section>
