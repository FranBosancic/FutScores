@model List<LeagueDetailsViewModel>

<div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
        <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Leagues</span>
        <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Competition hubs for club and match browsing</h2>
    </div>
    <div class="flex flex-col items-start gap-3 sm:items-end">
        <span class="text-sm text-slate-400">@Model.Count league@(Model.Count != 1 ? "s" : string.Empty) available</span>
        <a asp-route="league-create" class="inline-flex items-center rounded-full bg-lime-400 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-lime-300">Add league</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="mt-6 rounded-[1.5rem] border border-dashed border-white/10 bg-white/5 px-5 py-8 text-center text-slate-300">
        No leagues match the current search.
    </div>
}
else
{
    <div class="mt-6 grid gap-4 lg:grid-cols-2 xl:grid-cols-3">
        @foreach (var league in Model)
        {
            <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h3 class="text-xl font-semibold text-white">@league.Name</h3>
                        <p class="mt-1 text-sm text-slate-400">Competition overview</p>
                    </div>
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-200">League</span>
                </div>

                <div class="mt-4 grid gap-2 text-sm text-slate-300">
                    <span>Competition ID: #@league.Id</span>
                    <span>Clubs: @league.ClubCount</span>
                    <span>Matches: @league.MatchCount</span>
                </div>

                <div class="mt-5 flex flex-wrap gap-4 text-sm font-medium">
                    <a asp-route="matches-index" class="text-lime-300 transition hover:text-lime-200">Open matches</a>
                    <a asp-route="league-details" asp-route-id="@league.Id" class="text-lime-300 transition hover:text-lime-200">Open league</a>
                    <a asp-route="league-edit" asp-route-id="@league.Id" class="text-lime-300 transition hover:text-lime-200">Edit</a>
                    <a asp-route="league-delete" asp-route-id="@league.Id" class="text-rose-300 transition hover:text-rose-200">Delete</a>
                </div>
            </article>
        }
    </div>
}