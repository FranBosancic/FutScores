@model League

@{
    ViewData["Title"] = "League Details - Match Center";
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <nav class="fs-match-kickoff">
            <a asp-controller="Home" asp-action="Index" class="fs-card-link">Home</a>
            <span> / </span>
            <a asp-controller="League" asp-action="Index" class="fs-card-link">Leagues</a>
            <span> / </span>
            <span>@Model.Name</span>
        </nav>

        <section class="fs-section">
            <div class="fs-entity-hero">
                <div>
                    <span class="fs-section-kicker">League Focus</span>
                    <h2>@Model.Name</h2>
                    <p class="fs-match-kickoff">Competition hub for clubs, players, and results.</p>
                </div>
                <span class="fs-tone-pill fs-tone-pill--neutral">League #@Model.Id</span>
            </div>
        </section>

        <section class="fs-section fs-two-column">
            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">League Information</span>
                        <h2>Core competition identity</h2>
                    </div>
                </div>

                <div class="fs-detail-panel-grid">
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">League Name</span>
                        <strong>@Model.Name</strong>
                    </article>
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Competition ID</span>
                        <strong>#@Model.Id</strong>
                    </article>
                </div>
            </div>

            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">Quick Routes</span>
                        <h2>Move through the competition</h2>
                    </div>
                </div>

                <div class="fs-player-grid">
                    <article class="fs-player-card fs-player-card--entity">
                        <div class="fs-player-card-top">
                            <div>
                                <h3>Clubs</h3>
                                <p>Browse all club hubs</p>
                            </div>
                        </div>
                        <a asp-controller="Club" asp-action="Index" class="fs-card-link">Open clubs</a>
                    </article>

                    <article class="fs-player-card fs-player-card--entity">
                        <div class="fs-player-card-top">
                            <div>
                                <h3>Matches</h3>
                                <p>Follow competition results</p>
                            </div>
                        </div>
                        <a asp-controller="Match" asp-action="Index" class="fs-card-link">Open matches</a>
                    </article>
                </div>
            </div>
        </section>

        <div>
            <a asp-controller="League" asp-action="Index" class="fs-card-link">Back to all leagues</a>
        </div>
    </div>
</section>
