@model PlayerDetailsViewModel

@{
    ViewData["Title"] = "Player Details - Match Center";
}

@{
    var toneClass = Model.Position switch
    {
        Position.Goalkeeper => "border-indigo-400/20 bg-indigo-500/10 text-indigo-200",
        Position.Defender => "border-emerald-400/20 bg-emerald-500/10 text-emerald-200",
        Position.Midfielder => "border-amber-400/20 bg-amber-500/10 text-amber-200",
        Position.Forward => "border-rose-400/20 bg-rose-500/10 text-rose-200",
        _ => "border-white/10 bg-white/5 text-slate-200"
    };
    var age = DateTime.Today.Year - Model.DateOfBirth.Year;
    if (Model.DateOfBirth.Date > DateTime.Today.AddYears(-age))
    {
        age--;
    }
}

<section class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-slate-400">
        <a asp-controller="Home" asp-action="Index" class="font-medium text-lime-300 transition hover:text-lime-200">Home</a>
        <span class="px-2 text-slate-600">/</span>
        <a asp-controller="Player" asp-action="Index" class="font-medium text-lime-300 transition hover:text-lime-200">Players</a>
        <span class="px-2 text-slate-600">/</span>
        <span>@Model.FirstName @Model.LastName</span>
    </nav>

    <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Player Focus</span>
                <h2 class="mt-2 font-['Oswald'] text-4xl leading-none text-white">@Model.FirstName @Model.LastName</h2>
                <p class="mt-3 text-sm text-slate-400">@Model.ClubName · @Model.Nationality</p>
            </div>
            <span class="rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] @toneClass">@Model.Position</span>
        </div>
    </section>

    <section class="grid gap-8 xl:grid-cols-2">
        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Player Information</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Identity and context</h2>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-1">
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Position</div>
                    <strong class="mt-3 block text-lg text-white">@Model.Position</strong>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Nationality</div>
                    <strong class="mt-3 block text-lg text-white">@Model.Nationality</strong>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 sm:col-span-2 xl:col-span-1">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Born</div>
                    <strong class="mt-3 block text-lg text-white">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</strong>
                </article>
            </div>
        </section>

        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Related Entity</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Club-first navigation</h2>
            </div>

            <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h3 class="text-xl font-semibold text-white">@Model.ClubName</h3>
                        <p class="mt-1 text-sm text-slate-400">Current club context</p>
                    </div>
                    <span class="inline-flex h-11 min-w-[2.75rem] items-center justify-center rounded-full bg-amber-400/15 px-3 font-['Oswald'] text-xl text-amber-200">@age</span>
                </div>
                <div class="mt-4 grid gap-2 text-sm text-slate-300">
                    <span>Age: @age</span>
                    <span>Role: @Model.Position</span>
                </div>
                <div class="mt-5 flex flex-wrap gap-4 text-sm font-medium">
                    <a asp-controller="Club" asp-action="Details" asp-route-id="@Model.ClubId" class="text-lime-300 transition hover:text-lime-200">Open club</a>
                    <a asp-controller="Player" asp-action="Index" class="text-lime-300 transition hover:text-lime-200">More players</a>
                </div>
            </article>
        </section>
    </section>

    <div>
        <a asp-controller="Player" asp-action="Index" class="text-sm font-medium text-lime-300 transition hover:text-lime-200">Back to all players</a>
    </div>
</section>
