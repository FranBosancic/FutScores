@model PlayerDetailsViewModel

@{
    ViewData["Title"] = "Player Details";
}

<div class="bg-slate-900 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Breadcrumb -->
        <nav class="mb-6">
            <a asp-controller="Home" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 transition-colors">Home</a>
            <span class="text-slate-500 mx-2">›</span>
            <a asp-controller="Player" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 transition-colors">Players</a>
            <span class="text-slate-500 mx-2">›</span>
            <span class="text-slate-300">@Model.FirstName @Model.LastName</span>
        </nav>

        <!-- Header -->
        <div class="mb-8">
            <div class="flex items-start justify-between mb-4">
                <div>
                    <h1 class="text-4xl font-bold text-slate-50 mb-2">@Model.FirstName @Model.LastName</h1>
                    @{
                        string positionColor = Model.Position switch
                        {
                            Position.Goalkeeper => "bg-indigo-500",
                            Position.Defender => "bg-emerald-500",
                            Position.Midfielder => "bg-amber-500",
                            Position.Forward => "bg-red-500",
                            _ => "bg-slate-600"
                        };
                    }
                    <span class="@positionColor text-white text-sm font-bold px-4 py-1 rounded-full">@Model.Position</span>
                </div>
            </div>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <!-- Player Information Card -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                <h2 class="text-2xl font-semibold text-slate-50 mb-6">Player Information</h2>

                <div class="space-y-4">
                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Position</p>
                        <p class="text-slate-50 font-medium">@Model.Position</p>
                    </div>

                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Nationality</p>
                        <p class="text-slate-50 font-medium">@Model.Nationality</p>
                    </div>

                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Date of Birth</p>
                        <p class="text-slate-50 font-medium">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</p>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-1">Club</p>
                        <a asp-controller="Club" asp-action="Details" asp-route-id="@Model.ClubId" class="text-emerald-400 font-medium hover:text-emerald-300 transition-colors">@Model.ClubName</a>
                    </div>
                </div>
            </div>

            <!-- Related Information Card -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                <h2 class="text-2xl font-semibold text-slate-50 mb-6">Quick Stats</h2>

                <div class="space-y-4">
                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Age</p>
                        <p class="text-slate-50 font-medium">@((DateTime.Now.Year - Model.DateOfBirth.Year)) years old</p>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-2">Current Club</p>
                        <a asp-controller="Club" asp-action="Details" asp-route-id="@Model.ClubId" class="text-slate-300 text-sm hover:text-emerald-300 transition-colors">@Model.ClubName</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-8">
            <a asp-controller="Player" asp-action="Index" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2 rounded-md transition-colors font-medium inline-block">← Back to Players</a>
        </div>
    </div>
</div>
