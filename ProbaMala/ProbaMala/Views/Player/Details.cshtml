@model PlayerDetailsViewModel

@{
    ViewData["Title"] = "Player Details - Match Center";
}

@{
    var toneClass = Model.Position switch
    {
        Position.Goalkeeper => "fs-tone-pill--keeper",
        Position.Defender => "fs-tone-pill--defender",
        Position.Midfielder => "fs-tone-pill--midfielder",
        Position.Forward => "fs-tone-pill--forward",
        _ => "fs-tone-pill--neutral"
    };
    var age = DateTime.Today.Year - Model.DateOfBirth.Year;
    if (Model.DateOfBirth.Date > DateTime.Today.AddYears(-age))
    {
        age--;
    }
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <nav class="fs-match-kickoff">
            <a asp-controller="Home" asp-action="Index" class="fs-card-link">Home</a>
            <span> / </span>
            <a asp-controller="Player" asp-action="Index" class="fs-card-link">Players</a>
            <span> / </span>
            <span>@Model.FirstName @Model.LastName</span>
        </nav>

        <section class="fs-section">
            <div class="fs-entity-hero">
                <div>
                    <span class="fs-section-kicker">Player Focus</span>
                    <h2>@Model.FirstName @Model.LastName</h2>
                    <p class="fs-match-kickoff">@Model.ClubName · @Model.Nationality</p>
                </div>
                <span class="fs-tone-pill @toneClass">@Model.Position</span>
            </div>
        </section>

        <section class="fs-section fs-two-column">
            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">Player Information</span>
                        <h2>Identity and context</h2>
                    </div>
                </div>

                <div class="fs-detail-panel-grid">
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Position</span>
                        <strong>@Model.Position</strong>
                    </article>
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Nationality</span>
                        <strong>@Model.Nationality</strong>
                    </article>
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Born</span>
                        <strong>@Model.DateOfBirth.ToString("MMMM dd, yyyy")</strong>
                    </article>
                </div>
            </div>

            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">Related Entity</span>
                        <h2>Club-first navigation</h2>
                    </div>
                </div>

                <div class="fs-player-card fs-player-card--entity">
                    <div class="fs-player-card-top">
                        <div>
                            <h3>@Model.ClubName</h3>
                            <p>Current club context</p>
                        </div>
                        <span class="fs-rating-pill">@age</span>
                    </div>
                    <div class="fs-player-meta fs-player-meta--stacked">
                        <span>Age: @age</span>
                        <span>Role: @Model.Position</span>
                    </div>
                    <div class="fs-entity-links">
                        <a asp-controller="Club" asp-action="Details" asp-route-id="@Model.ClubId" class="fs-card-link">Open club</a>
                        <a asp-controller="Player" asp-action="Index" class="fs-card-link">More players</a>
                    </div>
                </div>
            </div>
        </section>

        <div>
            <a asp-controller="Player" asp-action="Index" class="fs-card-link">Back to all players</a>
        </div>
    </div>
</section>
