@model List<PlayerDetailsViewModel>

<div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
        <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Players</span>
        <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Player browsing with club context built in</h2>
    </div>
    <div class="flex flex-col items-start gap-3 sm:items-end">
        <span class="text-sm text-slate-400">@Model.Count player@(Model.Count != 1 ? "s" : string.Empty) in the board</span>
        <a asp-route="player-create" class="inline-flex items-center rounded-full bg-lime-400 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-lime-300">Add player</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="mt-6 rounded-[1.5rem] border border-dashed border-white/10 bg-white/5 px-5 py-8 text-center text-slate-300">
        No players match the current search.
    </div>
}
else
{
    <div class="mt-6 grid gap-4 lg:grid-cols-2 xl:grid-cols-3">
        @foreach (var player in Model)
        {
            var toneClass = player.Position switch
            {
                Position.Goalkeeper => "border-indigo-400/20 bg-indigo-500/10 text-indigo-200",
                Position.Defender => "border-emerald-400/20 bg-emerald-500/10 text-emerald-200",
                Position.Midfielder => "border-amber-400/20 bg-amber-500/10 text-amber-200",
                Position.Forward => "border-rose-400/20 bg-rose-500/10 text-rose-200",
                _ => "border-white/10 bg-white/5 text-slate-200"
            };

            <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h3 class="text-xl font-semibold text-white">@player.FirstName @player.LastName</h3>
                        <p class="mt-1 text-sm text-slate-400">@player.ClubName</p>
                    </div>
                    <span class="rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] @toneClass">@player.Position</span>
                </div>

                <div class="mt-4 grid gap-2 text-sm text-slate-300">
                    <span>Nationality: @player.Nationality</span>
                    <span>Born: @player.DateOfBirth.ToString("MMM dd, yyyy")</span>
                    <span>Ratings: @player.RatingCount</span>
                </div>

                <div class="mt-5 flex flex-wrap gap-4 text-sm font-medium">
                    <a asp-route="club-details" asp-route-id="@player.ClubId" class="text-lime-300 transition hover:text-lime-200">Open club</a>
                    <a asp-route="player-details" asp-route-id="@player.Id" class="text-lime-300 transition hover:text-lime-200">Open player</a>
                    <a asp-route="player-edit" asp-route-id="@player.Id" class="text-lime-300 transition hover:text-lime-200">Edit</a>
                    <a asp-route="player-delete" asp-route-id="@player.Id" class="text-rose-300 transition hover:text-rose-200">Delete</a>
                </div>
            </article>
        }
    </div>
}