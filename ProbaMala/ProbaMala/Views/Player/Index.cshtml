@model List<PlayerDetailsViewModel>

@{
    ViewData["Title"] = "Players - Match Center";
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <section class="fs-section">
            <div class="fs-section-heading">
                <div>
                    <span class="fs-section-kicker">Players</span>
                    <h2>Player browsing with club context built in</h2>
                </div>
                <span class="fs-match-kickoff">@Model.Count player@(Model.Count != 1 ? "s" : string.Empty) in the board</span>
            </div>

            <div class="fs-player-grid fs-player-grid--wide">
                @foreach (var player in Model)
                {
                    var toneClass = player.Position switch
                    {
                        Position.Goalkeeper => "fs-tone-pill--keeper",
                        Position.Defender => "fs-tone-pill--defender",
                        Position.Midfielder => "fs-tone-pill--midfielder",
                        Position.Forward => "fs-tone-pill--forward",
                        _ => "fs-tone-pill--neutral"
                    };

                    <article class="fs-player-card fs-player-card--entity">
                        <div class="fs-player-card-top">
                            <div>
                                <h3>@player.FirstName @player.LastName</h3>
                                <p>@player.ClubName</p>
                            </div>
                            <span class="fs-tone-pill @toneClass">@player.Position</span>
                        </div>

                        <div class="fs-player-meta fs-player-meta--stacked">
                            <span>Nationality: @player.Nationality</span>
                            <span>Born: @player.DateOfBirth.ToString("MMM dd, yyyy")</span>
                        </div>

                        <div class="fs-entity-links">
                            <a asp-controller="Club" asp-action="Details" asp-route-id="@player.ClubId" class="fs-card-link">Open club</a>
                            <a asp-controller="Player" asp-action="Details" asp-route-id="@player.Id" class="fs-card-link">Open player</a>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
</section>
