@model List<PlayerDetailsViewModel>

@{
    ViewData["Title"] = "Players";
}

<h1>Players</h1>

<table border="1" cellpadding="10" cellspacing="0">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Nationality</th>
            <th>Club Name</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var player in Model)
        {
            <tr>
                <td>@player.FirstName</td>
                <td>@player.LastName</td>
                <td>@player.Nationality</td>
                <td>@player.ClubName</td>
                <td>
                    <a href="@Url.Action("Details", "Player", new { id = player.Id })">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>
