@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FutScores</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/tailwind.generated.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProbaMala.styles.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top_right,rgba(34,197,94,0.18),transparent_26%),linear-gradient(180deg,#08121e_0%,#07111f_100%)] font-['Barlow'] text-slate-50">
    <header class="sticky top-0 z-30 border-b border-white/10 bg-slate-950/80 backdrop-blur">
        <div class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:gap-6 sm:px-6 lg:px-8">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="flex min-w-0 items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-3 py-2 text-white transition hover:bg-white/10 sm:px-4">
                <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-lime-400 font-['Oswald'] text-lg font-bold text-slate-950 shadow-[0_10px_30px_rgba(34,197,94,0.25)]">FS</span>
                <span class="grid min-w-0">
                    <span class="truncate font-['Oswald'] text-3xl leading-none tracking-wide">FutScores</span>
                    <span class="truncate text-sm text-slate-400">Scores, clubs, players, leagues</span>
                </span>
            </a>

            <form class="hidden min-w-0 flex-1 grid-cols-[110px_minmax(0,1fr)_auto] gap-2 lg:grid" data-search-form>
                <label class="sr-only" for="shell-search-scope">Search scope</label>
                <select id="shell-search-scope" class="h-12 rounded-full border border-white/10 bg-white/5 px-4 text-sm text-slate-100 outline-none transition focus:border-lime-400/60 focus:bg-white/10" data-search-scope>
                    <option value="Match">Matches</option>
                    <option value="Player">Players</option>
                    <option value="Club">Clubs</option>
                    <option value="League">Leagues</option>
                </select>
                <label class="sr-only" for="shell-search-query">Search query</label>
                <input id="shell-search-query" class="h-12 min-w-0 rounded-full border border-white/10 bg-white/5 px-5 text-sm text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-lime-400/60 focus:bg-white/10" type="search" placeholder="Search players, clubs, matches..." data-search-query />
                <button class="h-12 rounded-full bg-lime-400 px-5 text-sm font-semibold text-slate-950 transition hover:bg-lime-300" type="submit">Search</button>
            </form>

            <button id="mobile-menu-btn" class="inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-white transition hover:bg-white/10 lg:hidden" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle navigation menu">
                <span class="flex flex-col gap-1.5">
                    <span class="block h-0.5 w-5 bg-current"></span>
                    <span class="block h-0.5 w-5 bg-current"></span>
                    <span class="block h-0.5 w-5 bg-current"></span>
                </span>
            </button>
        </div>

        <div class="mx-auto w-full max-w-7xl px-4 pb-4 sm:px-6 lg:px-8">
            <nav class="hidden flex-wrap gap-2 lg:flex" aria-label="Primary">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-medium transition @(currentController == "Home" && currentAction == "Index" ? "bg-lime-400 text-slate-950 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.2)]" : "bg-white/5 text-slate-300 hover:bg-white/10 hover:text-white")">Dashboard</a>
                <a asp-area="" asp-controller="Match" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-medium transition @(currentController == "Match" ? "bg-lime-400 text-slate-950 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.2)]" : "bg-white/5 text-slate-300 hover:bg-white/10 hover:text-white")">Matches</a>
                <a asp-area="" asp-controller="Player" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-medium transition @(currentController == "Player" ? "bg-lime-400 text-slate-950 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.2)]" : "bg-white/5 text-slate-300 hover:bg-white/10 hover:text-white")">Players</a>
                <a asp-area="" asp-controller="Club" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-medium transition @(currentController == "Club" ? "bg-lime-400 text-slate-950 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.2)]" : "bg-white/5 text-slate-300 hover:bg-white/10 hover:text-white")">Clubs</a>
                <a asp-area="" asp-controller="League" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-medium transition @(currentController == "League" ? "bg-lime-400 text-slate-950 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.2)]" : "bg-white/5 text-slate-300 hover:bg-white/10 hover:text-white")">Leagues</a>
                <a asp-area="" asp-controller="Rating" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-medium transition @(currentController == "Rating" ? "bg-lime-400 text-slate-950 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.2)]" : "bg-white/5 text-slate-300 hover:bg-white/10 hover:text-white")">Ratings</a>
                <a asp-area="" asp-controller="User" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-medium transition @(currentController == "User" ? "bg-lime-400 text-slate-950 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.2)]" : "bg-white/5 text-slate-400 hover:bg-white/10 hover:text-white")">Users</a>
            </nav>
        </div>

        <div id="mobile-menu" class="border-t border-white/10 bg-slate-950/95 lg:hidden" hidden>
            <div class="mx-auto grid w-full max-w-7xl gap-2 px-4 py-4 sm:px-6 lg:px-8">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="rounded-2xl bg-white/5 px-4 py-3 text-sm font-medium text-slate-100 transition hover:bg-white/10">Dashboard</a>
                <a asp-area="" asp-controller="Match" asp-action="Index" class="rounded-2xl bg-white/5 px-4 py-3 text-sm font-medium text-slate-100 transition hover:bg-white/10">Matches</a>
                <a asp-area="" asp-controller="Player" asp-action="Index" class="rounded-2xl bg-white/5 px-4 py-3 text-sm font-medium text-slate-100 transition hover:bg-white/10">Players</a>
                <a asp-area="" asp-controller="Club" asp-action="Index" class="rounded-2xl bg-white/5 px-4 py-3 text-sm font-medium text-slate-100 transition hover:bg-white/10">Clubs</a>
                <a asp-area="" asp-controller="League" asp-action="Index" class="rounded-2xl bg-white/5 px-4 py-3 text-sm font-medium text-slate-100 transition hover:bg-white/10">Leagues</a>
                <a asp-area="" asp-controller="Rating" asp-action="Index" class="rounded-2xl bg-white/5 px-4 py-3 text-sm font-medium text-slate-100 transition hover:bg-white/10">Ratings</a>
                <a asp-area="" asp-controller="User" asp-action="Index" class="rounded-2xl bg-white/5 px-4 py-3 text-sm font-medium text-slate-100 transition hover:bg-white/10">Users</a>
            </div>
        </div>
    </header>

    <main class="py-8" role="main">
        @RenderBody()
    </main>

    <footer class="border-t border-white/10 bg-slate-950/60">
        <div class="mx-auto flex w-full max-w-7xl flex-col justify-between gap-3 px-4 py-6 text-sm text-slate-400 sm:flex-row sm:items-center sm:px-6 lg:px-8">
            <div class="flex flex-col gap-1">
                <strong>FutScores</strong>
                <span>Football data browser ready for real APIs next.</span>
            </div>
            <div>&copy; 2026 FutScores</div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
