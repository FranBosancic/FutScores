@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FutScores</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProbaMala.styles.css" asp-append-version="true" />
</head>
<body class="fs-app-shell">
    <header class="fs-shell-header">
        <div class="fs-topbar">
            <div class="fs-shell-wrap">
                <span class="fs-topbar-kicker">Live Match Center</span>
                <span class="fs-topbar-copy">Dashboard-first football browsing built for match flow, club context, and player discovery.</span>
            </div>
        </div>

        <div class="fs-shell-wrap fs-header-main">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="fs-brand-block">
                <span class="fs-brand-mark">FS</span>
                <span class="fs-brand-copy">
                    <span class="fs-brand-name">FutScores</span>
                    <span class="fs-brand-tag">Bold football stats and score tracking</span>
                </span>
            </a>

            <form class="fs-shell-search" data-search-form>
                <label class="fs-visually-hidden" for="shell-search-scope">Search scope</label>
                <select id="shell-search-scope" class="fs-shell-search-select" data-search-scope>
                    <option value="Match">Matches</option>
                    <option value="Player">Players</option>
                    <option value="Club">Clubs</option>
                    <option value="League">Leagues</option>
                </select>
                <label class="fs-visually-hidden" for="shell-search-query">Search query</label>
                <input id="shell-search-query" class="fs-shell-search-input" type="search" placeholder="Search players, clubs, matches..." data-search-query />
                <button class="fs-shell-search-button" type="submit">Go</button>
            </form>

            <button id="mobile-menu-btn" class="fs-mobile-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu">
                <span class="fs-mobile-toggle-line"></span>
                <span class="fs-mobile-toggle-line"></span>
                <span class="fs-mobile-toggle-line"></span>
            </button>
        </div>

        <div class="fs-shell-wrap">
            <nav class="fs-main-nav" aria-label="Primary">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="fs-nav-link @(currentController == "Home" && currentAction == "Index" ? "is-active" : string.Empty)">Dashboard</a>
                <a asp-area="" asp-controller="Match" asp-action="Index" class="fs-nav-link @(currentController == "Match" ? "is-active" : string.Empty)">Matches</a>
                <a asp-area="" asp-controller="Player" asp-action="Index" class="fs-nav-link @(currentController == "Player" ? "is-active" : string.Empty)">Players</a>
                <a asp-area="" asp-controller="Club" asp-action="Index" class="fs-nav-link @(currentController == "Club" ? "is-active" : string.Empty)">Clubs</a>
                <a asp-area="" asp-controller="League" asp-action="Index" class="fs-nav-link @(currentController == "League" ? "is-active" : string.Empty)">Leagues</a>
                <a asp-area="" asp-controller="Rating" asp-action="Index" class="fs-nav-link @(currentController == "Rating" ? "is-active" : string.Empty)">Ratings</a>
                <a asp-area="" asp-controller="User" asp-action="Index" class="fs-nav-link fs-nav-link--minor @(currentController == "User" ? "is-active" : string.Empty)">Users</a>
            </nav>
        </div>

        <div id="mobile-menu" class="fs-mobile-menu" hidden>
            <div class="fs-shell-wrap fs-mobile-menu-inner">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="fs-mobile-link">Dashboard</a>
                <a asp-area="" asp-controller="Match" asp-action="Index" class="fs-mobile-link">Matches</a>
                <a asp-area="" asp-controller="Player" asp-action="Index" class="fs-mobile-link">Players</a>
                <a asp-area="" asp-controller="Club" asp-action="Index" class="fs-mobile-link">Clubs</a>
                <a asp-area="" asp-controller="League" asp-action="Index" class="fs-mobile-link">Leagues</a>
                <a asp-area="" asp-controller="Rating" asp-action="Index" class="fs-mobile-link">Ratings</a>
                <a asp-area="" asp-controller="User" asp-action="Index" class="fs-mobile-link">Users</a>
            </div>
        </div>
    </header>

    <main class="fs-shell-main" role="main">
        @RenderBody()
    </main>

    <footer class="fs-footer">
        <div class="fs-shell-wrap fs-footer-inner">
            <div>
                <strong>FutScores</strong>
                <span class="fs-footer-copy">Football match center shell built for real data next.</span>
            </div>
            <div>&copy; 2026 FutScores</div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
