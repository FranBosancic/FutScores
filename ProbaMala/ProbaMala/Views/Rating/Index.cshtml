@model List<RatingDetailsViewModel>

@{
    ViewData["Title"] = "Ratings";
}

<h1>Ratings</h1>

<table border="1" cellpadding="10" cellspacing="0">
    <thead>
        <tr>
            <th>Player</th>
            <th>Match</th>
            <th>User</th>
            <th>Score</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var rating in Model)
        {
            <tr>
                <td>@rating.PlayerName</td>
                <td>@rating.MatchDescription</td>
                <td>@rating.UserName</td>
                <td>@rating.Score</td>
                <td><a href="@Url.Action("Details", "Rating", new { id = rating.Id })">View</a></td>
            </tr>
        }
    </tbody>
</table>
