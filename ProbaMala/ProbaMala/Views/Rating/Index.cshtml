@model List<RatingDetailsViewModel>

@{
    ViewData["Title"] = "Ratings - Match Center";
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <section class="fs-section">
            <div class="fs-section-heading">
                <div>
                    <span class="fs-section-kicker">Ratings</span>
                    <h2>Player sentiment layered onto match context</h2>
                </div>
                <span class="fs-match-kickoff">@Model.Count rating@(Model.Count != 1 ? "s" : string.Empty) tracked</span>
            </div>

            <div class="fs-player-grid fs-player-grid--wide">
                @foreach (var rating in Model)
                {
                    <article class="fs-player-card fs-player-card--entity">
                        <div class="fs-player-card-top">
                            <div>
                                <h3>@rating.PlayerName</h3>
                                <p>@rating.MatchDescription</p>
                            </div>
                            <span class="fs-rating-pill">@rating.Score</span>
                        </div>

                        <div class="fs-player-meta fs-player-meta--stacked">
                            <span>Rated by: @rating.UserName</span>
                            @if (!string.IsNullOrWhiteSpace(rating.Comment))
                            {
                                <span>"@rating.Comment"</span>
                            }
                            else
                            {
                                <span>No written comment provided</span>
                            }
                        </div>

                        <div class="fs-entity-links">
                            <a asp-controller="Rating" asp-action="Details" asp-route-id="@rating.Id" class="fs-card-link">Open rating</a>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
</section>
