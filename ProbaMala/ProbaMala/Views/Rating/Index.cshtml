@model List<RatingDetailsViewModel>

@{
    ViewData["Title"] = "Ratings - Match Center";
    var filterQuery = ViewData["FilterQuery"]?.ToString() ?? string.Empty;
}

<section class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 sm:px-6 lg:px-8">
    <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
        <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-xl">
                <label for="ratings-filter" class="mb-2 block text-sm font-medium uppercase tracking-[0.18em] text-slate-400">Live Search</label>
                <input id="ratings-filter"
                       type="search"
                       value="@filterQuery"
                       placeholder="Filter by player, user, club, score, or comment"
                       class="w-full rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-lime-400/60 focus:bg-white/10"
                       data-live-filter-input
                       data-filter-url="@Url.RouteUrl("ratings-filter")"
                       data-filter-target="ratings-filter-results" />
                <p class="mt-2 text-sm text-slate-500">Results update automatically while you type.</p>
            </div>
        </div>

        <div id="ratings-filter-results" data-live-filter-results>
            <partial name="_RatingList" model="Model" />
        </div>
    </section>
</section>
