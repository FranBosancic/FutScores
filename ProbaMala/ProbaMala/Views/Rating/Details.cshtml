@model RatingDetailsViewModel

@{
    ViewData["Title"] = "Rating Details - Match Center";
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <nav class="fs-match-kickoff">
            <a asp-controller="Home" asp-action="Index" class="fs-card-link">Home</a>
            <span> / </span>
            <a asp-controller="Rating" asp-action="Index" class="fs-card-link">Ratings</a>
            <span> / </span>
            <span>Rating #@Model.Id</span>
        </nav>

        <section class="fs-section">
            <div class="fs-entity-hero">
                <div>
                    <span class="fs-section-kicker">Rating Focus</span>
                    <h2>@Model.PlayerName</h2>
                    <p class="fs-match-kickoff">Assessment tied to @Model.MatchDescription</p>
                </div>
                <span class="fs-rating-pill fs-rating-pill--large">@Model.Score</span>
            </div>
        </section>

        <section class="fs-section fs-two-column">
            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">Rating Information</span>
                        <h2>Who and what this score belongs to</h2>
                    </div>
                </div>

                <div class="fs-detail-panel-grid">
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Player</span>
                        <a asp-controller="Player" asp-action="Details" asp-route-id="@Model.PlayerId" class="fs-card-link">@Model.PlayerName</a>
                    </article>
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Match</span>
                        <a asp-controller="Match" asp-action="Details" asp-route-id="@Model.MatchId" class="fs-card-link">@Model.MatchDescription</a>
                    </article>
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Rated By</span>
                        <a asp-controller="User" asp-action="Details" asp-route-id="@Model.UserId" class="fs-card-link">@Model.UserName</a>
                    </article>
                </div>
            </div>

            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">Review</span>
                        <h2>Written context</h2>
                    </div>
                </div>

                <article class="fs-detail-info-card fs-detail-info-card--tall">
                    @if (!string.IsNullOrWhiteSpace(Model.Comment))
                    {
                        <p class="fs-review-copy">@Model.Comment</p>
                    }
                    else
                    {
                        <p class="fs-review-copy fs-review-copy--muted">No comment provided for this rating.</p>
                    }
                </article>
            </div>
        </section>

        <section class="fs-section">
            <div class="fs-section-heading">
                <div>
                    <span class="fs-section-kicker">Related Entities</span>
                    <h2>Jump to connected pages</h2>
                </div>
            </div>

            <div class="fs-player-grid">
                <article class="fs-player-card fs-player-card--entity">
                    <div class="fs-player-card-top">
                        <div>
                            <h3>Player</h3>
                            <p>@Model.PlayerName</p>
                        </div>
                    </div>
                    <a asp-controller="Player" asp-action="Details" asp-route-id="@Model.PlayerId" class="fs-card-link">Open player</a>
                </article>

                <article class="fs-player-card fs-player-card--entity">
                    <div class="fs-player-card-top">
                        <div>
                            <h3>Match</h3>
                            <p>@Model.MatchDescription</p>
                        </div>
                    </div>
                    <a asp-controller="Match" asp-action="Details" asp-route-id="@Model.MatchId" class="fs-card-link">Open match</a>
                </article>

                <article class="fs-player-card fs-player-card--entity">
                    <div class="fs-player-card-top">
                        <div>
                            <h3>User</h3>
                            <p>@Model.UserName</p>
                        </div>
                    </div>
                    <a asp-controller="User" asp-action="Details" asp-route-id="@Model.UserId" class="fs-card-link">Open user</a>
                </article>
            </div>
        </section>

        <div>
            <a asp-controller="Rating" asp-action="Index" class="fs-card-link">Back to all ratings</a>
        </div>
    </div>
</section>
