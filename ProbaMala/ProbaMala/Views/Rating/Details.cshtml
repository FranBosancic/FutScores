@model RatingDetailsViewModel

@{
    ViewData["Title"] = "Rating Details";
}

<div class="bg-slate-900 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Breadcrumb -->
        <nav class="mb-6">
            <a asp-controller="Home" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 transition-colors">Home</a>
            <span class="text-slate-500 mx-2">›</span>
            <a asp-controller="Rating" asp-action="Index" class="text-emerald-400 hover:text-emerald-300 transition-colors">Ratings</a>
            <span class="text-slate-500 mx-2">›</span>
            <span class="text-slate-300">Rating #@Model.Id</span>
        </nav>

        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-slate-50 mb-4">Rating #@Model.Id</h1>
            <div class="flex items-center space-x-4">
                <span class="bg-amber-500 text-white text-2xl font-bold px-4 py-2 rounded-lg">@Model.Score</span>
                <p class="text-slate-300">Rating by <a asp-controller="User" asp-action="Details" asp-route-id="@Model.UserId" class="text-emerald-400 hover:text-emerald-300 transition-colors">@Model.UserName</a></p>
            </div>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <!-- Rating Information Card -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                <h2 class="text-2xl font-semibold text-slate-50 mb-6">Rating Information</h2>

                <div class="space-y-4">
                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Player</p>
                        <a asp-controller="Player" asp-action="Details" asp-route-id="@Model.PlayerId" class="text-emerald-400 font-medium hover:text-emerald-300 transition-colors">@Model.PlayerName</a>
                    </div>

                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Match</p>
                        <a asp-controller="Match" asp-action="Details" asp-route-id="@Model.MatchId" class="text-slate-50 font-medium hover:text-emerald-300 transition-colors">@Model.MatchDescription</a>
                    </div>

                    <div class="pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-1">Rated by</p>
                        <a asp-controller="User" asp-action="Details" asp-route-id="@Model.UserId" class="text-emerald-400 font-medium hover:text-emerald-300 transition-colors">@Model.UserName</a>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-1">Score</p>
                        <div class="flex items-center space-x-2">
                            <span class="bg-amber-500 text-white font-bold px-3 py-1 rounded-lg">@Model.Score</span>
                            <span class="text-slate-400">out of 10</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comment Card -->
            <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                <h2 class="text-2xl font-semibold text-slate-50 mb-6">Review</h2>

                <div class="space-y-4">
                    @if (!string.IsNullOrEmpty(Model.Comment))
                    {
                        <div>
                            <p class="text-slate-300 mb-4">@Model.Comment</p>
                        </div>
                    }
                    else
                    {
                        <div>
                            <p class="text-slate-400 italic">No comment provided.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Related Entities Card -->
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6 mb-8">
            <h2 class="text-2xl font-semibold text-slate-50 mb-6">Related Entities</h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="pb-4 md:border-r md:border-slate-700 md:pr-4">
                    <p class="text-slate-400 text-sm mb-2">Player</p>
                    <a asp-controller="Player" asp-action="Details" asp-route-id="@Model.PlayerId" class="text-emerald-400 hover:text-emerald-300 font-medium transition-colors">View player details →</a>
                </div>
                <div class="pb-4 md:border-r md:border-slate-700 md:pr-4">
                    <p class="text-slate-400 text-sm mb-2">Match</p>
                    <a asp-controller="Match" asp-action="Details" asp-route-id="@Model.MatchId" class="text-emerald-400 hover:text-emerald-300 font-medium transition-colors">View match details →</a>
                </div>
                <div>
                    <p class="text-slate-400 text-sm mb-2">User</p>
                    <a asp-controller="User" asp-action="Details" asp-route-id="@Model.UserId" class="text-emerald-400 hover:text-emerald-300 font-medium transition-colors">View user details →</a>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-8">
            <a asp-controller="Rating" asp-action="Index" class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2 rounded-md transition-colors font-medium inline-block">← Back to Ratings</a>
        </div>
    </div>
</div>
