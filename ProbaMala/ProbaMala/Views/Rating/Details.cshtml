@model RatingDetailsViewModel

@{
    ViewData["Title"] = "Rating Details - Match Center";
    var scoreToneClass = Model.Score switch
    {
        >= 9 => "border-emerald-400/20 bg-emerald-500/10 text-emerald-200",
        >= 7 => "border-lime-400/20 bg-lime-500/10 text-lime-200",
        >= 5 => "border-amber-400/20 bg-amber-500/10 text-amber-200",
        _ => "border-rose-400/20 bg-rose-500/10 text-rose-200"
    };

    var scoreLabel = Model.Score switch
    {
        >= 9 => "Standout display",
        >= 7 => "Strong performance",
        >= 5 => "Mixed return",
        _ => "Underwhelming night"
    };
}

<section class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-slate-400">
        <a asp-route="home-index" class="font-medium text-lime-300 transition hover:text-lime-200">Home</a>
        <span class="px-2 text-slate-600">/</span>
        <a asp-route="ratings-index" class="font-medium text-lime-300 transition hover:text-lime-200">Ratings</a>
        <span class="px-2 text-slate-600">/</span>
        <span>Rating #@Model.Id</span>
    </nav>

    <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Rating Focus</span>
                <h2 class="mt-2 font-['Oswald'] text-4xl leading-none text-white">@Model.PlayerName</h2>
                <p class="mt-3 text-sm text-slate-400">Assessment tied to @Model.MatchDescription</p>
                <span class="mt-4 inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] @scoreToneClass">@scoreLabel</span>
            </div>
            <span class="inline-flex h-16 min-w-[4rem] items-center justify-center rounded-full border px-5 font-['Oswald'] text-3xl @scoreToneClass">@Model.Score</span>
        </div>
    </section>

    <section class="grid gap-8 xl:grid-cols-2">
        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Rating Information</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Who and what this score belongs to</h2>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-1">
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Player</div>
                    <a asp-route="player-details" asp-route-id="@Model.PlayerId" class="mt-3 block text-lg font-semibold text-lime-300 transition hover:text-lime-200">@Model.PlayerName</a>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Match</div>
                    <a asp-route="match-details" asp-route-id="@Model.MatchId" class="mt-3 block text-lg font-semibold text-lime-300 transition hover:text-lime-200">@Model.MatchDescription</a>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 sm:col-span-2 xl:col-span-1">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Rated By</div>
                    <a asp-route="user-details" asp-route-id="@Model.UserId" class="mt-3 block text-lg font-semibold text-lime-300 transition hover:text-lime-200">@Model.UserName</a>
                </article>
            </div>
        </section>

        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Review</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Written context</h2>
            </div>

            <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                @if (!string.IsNullOrWhiteSpace(Model.Comment))
                {
                    <p class="text-base leading-7 text-slate-200">@Model.Comment</p>
                }
                else
                {
                    <p class="text-base italic leading-7 text-slate-400">No comment provided for this rating.</p>
                }
            </article>

            <div class="mt-4 rounded-[1.5rem] border px-5 py-4 @scoreToneClass">
                <div class="text-xs uppercase tracking-[0.22em]">Score Reading</div>
                <div class="mt-2 text-lg font-semibold">@scoreLabel</div>
                <div class="mt-1 text-sm opacity-80">The numeric rating and written note are being read together as one assessment.</div>
            </div>
        </section>
    </section>

    <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
        <div class="mb-5">
            <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Related Entities</span>
            <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Jump to connected pages</h2>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
            <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                <div>
                    <h3 class="text-xl font-semibold text-white">Player</h3>
                    <p class="mt-1 text-sm text-slate-400">@Model.PlayerName</p>
                </div>
                <a asp-route="player-details" asp-route-id="@Model.PlayerId" class="mt-5 text-sm font-medium text-lime-300 transition hover:text-lime-200">Open player</a>
            </article>

            <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                <div>
                    <h3 class="text-xl font-semibold text-white">Match</h3>
                    <p class="mt-1 text-sm text-slate-400">@Model.MatchDescription</p>
                </div>
                <a asp-route="match-details" asp-route-id="@Model.MatchId" class="mt-5 text-sm font-medium text-lime-300 transition hover:text-lime-200">Open match</a>
            </article>

            <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                <div>
                    <h3 class="text-xl font-semibold text-white">User</h3>
                    <p class="mt-1 text-sm text-slate-400">@Model.UserName</p>
                </div>
                <a asp-route="user-details" asp-route-id="@Model.UserId" class="mt-5 text-sm font-medium text-lime-300 transition hover:text-lime-200">Open user</a>
            </article>
        </div>
    </section>

    <div class="flex flex-wrap items-center gap-4">
        <a asp-route="ratings-index" class="text-sm font-medium text-lime-300 transition hover:text-lime-200">Back to all ratings</a>
        <a asp-route="rating-edit" asp-route-id="@Model.Id" class="text-sm font-medium text-lime-300 transition hover:text-lime-200">Edit rating</a>
        <a asp-route="rating-delete" asp-route-id="@Model.Id" class="text-sm font-medium text-rose-300 transition hover:text-rose-200">Delete rating</a>
    </div>
</section>
