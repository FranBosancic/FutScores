@model RatingDetailsViewModel

@{
    ViewData["Title"] = "Delete Rating - Match Center";
}

<section class="mx-auto flex w-full max-w-4xl flex-col gap-8 px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-slate-400">
        <a asp-route="ratings-index" class="font-medium text-lime-300 transition hover:text-lime-200">Ratings</a>
        <span class="px-2 text-slate-600">/</span>
        <a asp-route="rating-details" asp-route-id="@Model.Id" class="font-medium text-lime-300 transition hover:text-lime-200">Rating #@Model.Id</a>
        <span class="px-2 text-slate-600">/</span>
        <span>Delete</span>
    </nav>

    <section class="rounded-[1.75rem] border border-rose-400/20 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
        <div class="mb-6">
            <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-rose-300">Danger Zone</span>
            <h1 class="mt-2 font-['Oswald'] text-4xl leading-none text-white">Delete rating #@Model.Id</h1>
            <p class="mt-3 text-sm text-slate-400">This permanently removes the selected rating from the database.</p>
        </div>

        <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 text-slate-200">
            <div class="grid gap-3 text-sm sm:grid-cols-2">
                <div>
                    <div class="text-xs uppercase tracking-[0.18em] text-slate-500">Player</div>
                    <div class="mt-1">@Model.PlayerName</div>
                </div>
                <div>
                    <div class="text-xs uppercase tracking-[0.18em] text-slate-500">Match</div>
                    <div class="mt-1">@Model.MatchDescription</div>
                </div>
                <div>
                    <div class="text-xs uppercase tracking-[0.18em] text-slate-500">User</div>
                    <div class="mt-1">@Model.UserName</div>
                </div>
                <div>
                    <div class="text-xs uppercase tracking-[0.18em] text-slate-500">Score</div>
                    <div class="mt-1">@Model.Score</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Comment))
            {
                <div class="mt-4 border-t border-white/10 pt-4 text-sm text-slate-300">
                    @Model.Comment
                </div>
            }
        </article>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-6 flex flex-wrap gap-4">
            @Html.AntiForgeryToken()
            <button type="submit" class="inline-flex items-center rounded-full bg-rose-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-rose-300">Delete rating</button>
            <a asp-route="rating-details" asp-route-id="@Model.Id" class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-slate-100 transition hover:bg-white/10">Cancel</a>
        </form>
    </section>
</section>