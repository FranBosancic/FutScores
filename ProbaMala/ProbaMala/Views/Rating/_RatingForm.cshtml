@model RatingFormViewModel

@{
    var previewScore = Math.Clamp(Model.Score, 1, 10);
    var previewToneClass = previewScore switch
    {
        >= 9 => "border-emerald-400/20 bg-emerald-500/10 text-emerald-200",
        >= 7 => "border-lime-400/20 bg-lime-500/10 text-lime-200",
        >= 5 => "border-amber-400/20 bg-amber-500/10 text-amber-200",
        _ => "border-rose-400/20 bg-rose-500/10 text-rose-200"
    };

    var previewLabel = previewScore switch
    {
        >= 9 => "Standout display",
        >= 7 => "Strong performance",
        >= 5 => "Mixed return",
        _ => "Underwhelming night"
    };
}

<div asp-validation-summary="ModelOnly" class="mb-5 rounded-[1.25rem] border border-rose-400/25 bg-rose-500/10 px-4 py-3 text-sm text-rose-100"></div>

<input asp-for="Id" type="hidden" />

<div class="grid gap-6 xl:grid-cols-[minmax(0,1.4fr)_minmax(320px,0.9fr)]">
    <section class="space-y-6">
        <div class="grid gap-6 lg:grid-cols-2">
            <div>
        <label asp-for="PlayerId" class="mb-2 block text-sm font-medium text-slate-200"></label>
        <partial name="_AutocompleteField" model='new AutocompleteFieldViewModel
        {
            Label = "Player",
            HiddenInputName = nameof(Model.PlayerId),
            HiddenInputId = Html.IdFor(model => model.PlayerId).ToString(),
            HiddenValue = Model.PlayerId,
            VisibleInputName = nameof(Model.PlayerLabel),
            VisibleInputId = Html.IdFor(model => model.PlayerLabel).ToString(),
            VisibleValue = Model.PlayerLabel,
            SearchUrl = Url.RouteUrl("rating-player-search") ?? string.Empty,
            Placeholder = "Search players by first or last name",
            EmptyStateText = "No players found."
        }' />
        <span asp-validation-for="PlayerId" class="mt-2 block text-sm text-rose-300"></span>
            </div>

            <div>
        <label asp-for="MatchId" class="mb-2 block text-sm font-medium text-slate-200"></label>
        <select asp-for="MatchId" asp-items="Model.MatchOptions" class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-slate-100 outline-none transition focus:border-lime-400/60 focus:bg-white/10">
            <option value="">Select a match</option>
        </select>
        <span asp-validation-for="MatchId" class="mt-2 block text-sm text-rose-300"></span>
            </div>

            <div>
        <label asp-for="UserId" class="mb-2 block text-sm font-medium text-slate-200"></label>
        <select asp-for="UserId" asp-items="Model.UserOptions" class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-slate-100 outline-none transition focus:border-lime-400/60 focus:bg-white/10">
            <option value="">Select a user</option>
        </select>
        <span asp-validation-for="UserId" class="mt-2 block text-sm text-rose-300"></span>
            </div>

            <div class="rounded-[1.5rem] border border-white/10 bg-slate-950/30 p-4">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <div class="text-xs uppercase tracking-[0.18em] text-slate-500">Score Snapshot</div>
                        <div data-rating-score-label class="mt-2 text-lg font-semibold text-white">@previewLabel</div>
                        <div class="mt-1 text-sm text-slate-400">Shape the tone before adding the written review.</div>
                    </div>
                    <span data-rating-score-chip class="inline-flex h-14 min-w-[3.2rem] items-center justify-center rounded-full border px-4 font-['Oswald'] text-2xl @previewToneClass">@previewScore</span>
                </div>
            </div>
        </div>

        <div class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5" data-rating-score-root>
            <div class="flex items-center justify-between gap-4">
                <label asp-for="Score" class="block text-sm font-medium text-slate-200"></label>
                <span class="rounded-full border border-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">1 to 10 scale</span>
            </div>

            <div class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,1fr)_96px] lg:items-center">
                <input data-rating-score-range type="range" min="1" max="10" value="@previewScore" class="h-2 w-full cursor-pointer appearance-none rounded-full bg-white/10 accent-lime-400" />
                <input asp-for="Score" data-rating-score-input type="number" min="1" max="10" class="w-full rounded-2xl border border-white/10 bg-slate-950/35 px-4 py-3 text-center text-lg font-semibold text-slate-100 outline-none transition focus:border-lime-400/60 focus:bg-white/10" />
            </div>

            <div class="mt-4 flex justify-between text-xs uppercase tracking-[0.18em] text-slate-500">
                <span>Poor</span>
                <span>Average</span>
                <span>Elite</span>
            </div>
        </div>

        <span asp-validation-for="Score" class="mt-2 block text-sm text-rose-300"></span>
        <div>
            <div class="mb-2 flex items-center justify-between gap-4">
                <label asp-for="Comment" class="block text-sm font-medium text-slate-200"></label>
                <span class="text-xs uppercase tracking-[0.18em] text-slate-500"><span data-rating-comment-count>@(Model.Comment?.Length ?? 0)</span>/400</span>
            </div>
            <textarea asp-for="Comment" data-rating-comment-input maxlength="400" rows="7" class="w-full rounded-[1.5rem] border border-white/10 bg-white/5 px-4 py-3 text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-lime-400/60 focus:bg-white/10" placeholder="Summarise the performance: decisive actions, mistakes, overall control, or standout moments."></textarea>
        <span asp-validation-for="Comment" class="mt-2 block text-sm text-rose-300"></span>
        </div>
    </section>

    <aside class="rounded-[1.6rem] border border-white/10 bg-[linear-gradient(180deg,rgba(163,230,53,0.08),rgba(15,23,42,0.55))] p-5 shadow-[0_18px_40px_rgba(0,0,0,0.18)]">
        <div class="text-xs uppercase tracking-[0.22em] text-lime-300">Rating Guide</div>
        <h3 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Make the score readable</h3>
        <div class="mt-5 space-y-3 text-sm text-slate-300">
            <div class="rounded-2xl border border-emerald-400/20 bg-emerald-500/10 px-4 py-3">
                <strong class="block text-emerald-200">9-10</strong>
                Match-defining, elite impact, or clear man-of-the-match level.
            </div>
            <div class="rounded-2xl border border-lime-400/20 bg-lime-500/10 px-4 py-3">
                <strong class="block text-lime-200">7-8</strong>
                Strong contribution with visible positive influence across phases.
            </div>
            <div class="rounded-2xl border border-amber-400/20 bg-amber-500/10 px-4 py-3">
                <strong class="block text-amber-200">5-6</strong>
                Mixed or stable performance without decisive edge.
            </div>
            <div class="rounded-2xl border border-rose-400/20 bg-rose-500/10 px-4 py-3">
                <strong class="block text-rose-200">1-4</strong>
                Poor execution, costly moments, or little positive impact.
            </div>
        </div>
    </aside>
</div>