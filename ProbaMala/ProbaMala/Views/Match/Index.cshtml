@model List<MatchDetailsViewModel>

@{
    ViewData["Title"] = "Matches";
}

<h1>Matches</h1>

<table border="1" cellpadding="10" cellspacing="0">
    <thead>
        <tr>
            <th>Date</th>
            <th>League</th>
            <th>Home Team</th>
            <th>Away Team</th>
            <th>Score</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var match in Model)
        {
            <tr>
                <td>@match.Date.ToString("yyyy-MM-dd")</td>
                <td>@match.LeagueName</td>
                <td>@match.HomeTeamName</td>
                <td>@match.AwayTeamName</td>
                <td>@match.Score</td>
                <td><a href="@Url.Action("Details", "Match", new { id = match.Id })">View</a></td>
            </tr>
        }
    </tbody>
</table>
