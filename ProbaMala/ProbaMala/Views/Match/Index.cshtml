@model List<MatchDetailsViewModel>

@{
    ViewData["Title"] = "Matches - Match Center";
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <section class="fs-section">
            <div class="fs-section-heading">
                <div>
                    <span class="fs-section-kicker">Match Center</span>
                    <h2>Every result in one score-first stream</h2>
                </div>
                <span class="fs-match-kickoff">@Model.Count match@(Model.Count != 1 ? "es" : string.Empty) on the board</span>
            </div>

            <div class="fs-match-grid">
                @foreach (var match in Model)
                {
                    <article class="fs-match-card">
                        <header class="fs-match-card-top">
                            <div>
                                <span class="fs-match-league">@match.LeagueName</span>
                                <span class="fs-match-kickoff">@match.KickoffLabel</span>
                            </div>
                            <span class="fs-badge fs-badge--@match.StatusTone">@match.StatusLabel</span>
                        </header>

                        <div class="fs-match-body">
                            <div class="fs-team-row">
                                <span class="fs-team-name">@match.HomeTeamName</span>
                                <span class="fs-team-score">@match.HomeGoals</span>
                            </div>
                            <div class="fs-team-row">
                                <span class="fs-team-name fs-team-name--away">@match.AwayTeamName</span>
                                <span class="fs-team-score">@match.AwayGoals</span>
                            </div>
                        </div>

                        <footer class="fs-match-footer">
                            <span class="fs-match-scoreline">@match.Score</span>
                            <a asp-controller="Match" asp-action="Details" asp-route-id="@match.Id" class="fs-card-link">Open match</a>
                        </footer>
                    </article>
                }
            </div>
        </section>
    </div>
</section>
