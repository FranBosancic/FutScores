@model List<MatchDetailsViewModel>

@{
    ViewData["Title"] = "Matches";
}

<div class="bg-slate-900 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-slate-50 mb-2">Matches</h1>
            <p class="text-slate-300">@Model.Count item@(Model.Count != 1 ? "s" : "") found</p>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var match in Model)
            {
                <div class="bg-slate-800 border border-slate-700 rounded-lg p-6 hover:bg-slate-900 hover:border-emerald-500 transition-all duration-300 cursor-pointer">
                    <!-- Match Header -->
                    <div class="mb-4 pb-4 border-b border-slate-700">
                        <p class="text-slate-400 text-sm mb-2">@match.Date.ToString("MMMM dd, yyyy")</p>
                        <span class="bg-indigo-500 text-white text-xs font-bold px-3 py-1 rounded-full">@match.LeagueName</span>
                    </div>

                    <!-- Teams and Score -->
                    <div class="mb-4">
                        <div class="flex justify-between items-center mb-3">
                            <span class="text-slate-50 font-semibold flex-1">@match.HomeTeamName</span>
                            <span class="text-2xl font-bold text-emerald-400 mx-2">@match.HomeGoals</span>
                        </div>
                        <div class="text-center text-slate-400 text-sm mb-3">vs</div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-400 font-semibold flex-1">@match.AwayGoals</span>
                            <span class="text-slate-50 font-semibold flex-1 text-right">@match.AwayTeamName</span>
                        </div>
                    </div>

                    <!-- Score Display -->
                    <div class="bg-slate-900 rounded-lg p-3 text-center mb-4">
                        <p class="text-emerald-400 text-sm font-bold">@match.Score</p>
                    </div>

                    <div class="flex justify-end">
                        <a href="@Url.Action("Details", "Match", new { id = match.Id })" class="text-emerald-400 hover:text-emerald-300 font-medium transition-colors">View Details →</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
