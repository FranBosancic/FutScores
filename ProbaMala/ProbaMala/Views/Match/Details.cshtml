@model Match

@{
    ViewData["Title"] = "Match Details";
}

<h1>Match #@Model.Id</h1>

<div>
    <p><strong>Date:</strong> @Model.Date.ToString("yyyy-MM-dd")</p>
    <p><strong>League ID:</strong> @Model.LeagueId</p>
    <p><strong>Home Team ID:</strong> @Model.HomeTeamId</p>
    <p><strong>Away Team ID:</strong> @Model.AwayTeamId</p>
    <p><strong>Score:</strong> @Model.HomeGoals - @Model.AwayGoals</p>
</div>

<p><a href="@Url.Action("Index", "Match")">Back to Matches</a></p>
