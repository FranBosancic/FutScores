@model MatchDetailsViewModel

@{
    ViewData["Title"] = "Match Details";
}

<h1>Match #@Model.Id</h1>

<div>
    <p><strong>Date:</strong> @Model.Date.ToString("yyyy-MM-dd")</p>
    <p><strong>League:</strong> @Model.LeagueName</p>
    <p><strong>Home Team:</strong> @Model.HomeTeamName</p>
    <p><strong>Away Team:</strong> @Model.AwayTeamName</p>
    <p><strong>Score:</strong> @Model.Score</p>
</div>

<p><a href="@Url.Action("Index", "Match")">Back to Matches</a></p>
