@model MatchDetailsViewModel

@{
    ViewData["Title"] = "Match Details - Match Center";
}

<section class="fs-dashboard">
    <div class="fs-shell-wrap fs-dashboard-stack">
        <nav class="fs-match-kickoff">
            <a asp-controller="Home" asp-action="Index" class="fs-card-link">Home</a>
            <span> / </span>
            <a asp-controller="Match" asp-action="Index" class="fs-card-link">Matches</a>
            <span> / </span>
            <span>Match #@Model.Id</span>
        </nav>

        <section class="fs-section">
            <div class="fs-section-heading">
                <div>
                    <span class="fs-section-kicker">Match Breakdown</span>
                    <h2>@Model.HomeTeamName vs @Model.AwayTeamName</h2>
                </div>
                <span class="fs-badge fs-badge--@Model.StatusTone">@Model.StatusLabel</span>
            </div>

            <div class="fs-detail-scoreboard">
                <div class="fs-detail-team-block">
                    <span class="fs-match-kickoff">Home Club</span>
                    <a asp-controller="Club" asp-action="Details" asp-route-id="@Model.HomeTeamId" class="fs-detail-team-name">@Model.HomeTeamName</a>
                    <strong class="fs-detail-team-score">@Model.HomeGoals</strong>
                </div>

                <div class="fs-detail-center-block">
                    <span class="fs-match-league">@Model.LeagueName</span>
                    <strong class="fs-detail-scoreline">@Model.Score</strong>
                    <span class="fs-match-kickoff">@Model.KickoffLabel</span>
                </div>

                <div class="fs-detail-team-block">
                    <span class="fs-match-kickoff">Away Club</span>
                    <a asp-controller="Club" asp-action="Details" asp-route-id="@Model.AwayTeamId" class="fs-detail-team-name">@Model.AwayTeamName</a>
                    <strong class="fs-detail-team-score">@Model.AwayGoals</strong>
                </div>
            </div>
        </section>

        <section class="fs-section fs-two-column">
            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">Match Information</span>
                        <h2>Context on the fixture</h2>
                    </div>
                </div>

                <div class="fs-detail-panel-grid">
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Competition</span>
                        <a asp-controller="League" asp-action="Details" asp-route-id="@Model.LeagueId" class="fs-card-link">@Model.LeagueName</a>
                    </article>
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Kickoff</span>
                        <strong>@Model.Date.ToString("MMMM dd, yyyy")</strong>
                    </article>
                    <article class="fs-detail-info-card">
                        <span class="fs-match-kickoff">Status</span>
                        <strong>@Model.StatusLabel</strong>
                    </article>
                </div>
            </div>

            <div>
                <div class="fs-section-heading">
                    <div>
                        <span class="fs-section-kicker">Related Clubs</span>
                        <h2>Move deeper into the matchup</h2>
                    </div>
                </div>

                <div class="fs-player-grid">
                    <article class="fs-player-card">
                        <div class="fs-player-card-top">
                            <div>
                                <h3>@Model.HomeTeamName</h3>
                                <p>Home club context</p>
                            </div>
                        </div>
                        <div class="fs-player-meta">
                            <span>League: @Model.LeagueName</span>
                            <span>Goals: @Model.HomeGoals</span>
                        </div>
                        <a asp-controller="Club" asp-action="Details" asp-route-id="@Model.HomeTeamId" class="fs-card-link">Open home club</a>
                    </article>

                    <article class="fs-player-card">
                        <div class="fs-player-card-top">
                            <div>
                                <h3>@Model.AwayTeamName</h3>
                                <p>Away club context</p>
                            </div>
                        </div>
                        <div class="fs-player-meta">
                            <span>League: @Model.LeagueName</span>
                            <span>Goals: @Model.AwayGoals</span>
                        </div>
                        <a asp-controller="Club" asp-action="Details" asp-route-id="@Model.AwayTeamId" class="fs-card-link">Open away club</a>
                    </article>
                </div>
            </div>
        </section>

        <div>
            <a asp-controller="Match" asp-action="Index" class="fs-card-link">Back to all matches</a>
        </div>
    </div>
</section>
