@model MatchDetailsViewModel

@{
    ViewData["Title"] = "Match Details - Match Center";
}

@{
    var badgeClass = Model.StatusTone switch
    {
        "live" => "border-red-400/20 bg-red-500/10 text-red-200",
        "recent" => "border-sky-400/20 bg-sky-500/10 text-sky-200",
        _ => "border-emerald-400/20 bg-emerald-500/10 text-emerald-200"
    };
}

<section class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 sm:px-6 lg:px-8">
    <nav class="text-sm text-slate-400">
        <a asp-route="home-index" class="font-medium text-lime-300 transition hover:text-lime-200">Home</a>
        <span class="px-2 text-slate-600">/</span>
        <a asp-route="matches-index" class="font-medium text-lime-300 transition hover:text-lime-200">Matches</a>
        <span class="px-2 text-slate-600">/</span>
        <span>Match #@Model.Id</span>
    </nav>

    <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
        <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Match Breakdown</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white sm:text-4xl">@Model.HomeTeamName vs @Model.AwayTeamName</h2>
            </div>
            <span class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] @badgeClass">@Model.StatusLabel</span>
        </div>

        <div class="grid gap-4 rounded-[1.75rem] border border-white/10 bg-white/5 p-5 text-center lg:grid-cols-[1fr_auto_1fr] lg:items-center lg:p-6">
            <div class="space-y-3 rounded-[1.5rem] bg-slate-950/30 p-5">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Home Club</div>
                <a asp-route="club-details" asp-route-id="@Model.HomeTeamId" class="block font-['Oswald'] text-3xl text-white transition hover:text-lime-300">@Model.HomeTeamName</a>
                <div class="font-['Oswald'] text-6xl leading-none text-white">@Model.HomeGoals</div>
            </div>

            <div class="space-y-2 px-2 py-4 lg:px-4">
                <div class="font-['Oswald'] text-xs uppercase tracking-[0.22em] text-slate-500">@Model.LeagueName</div>
                <div class="font-['Oswald'] text-4xl text-white sm:text-5xl">@Model.Score</div>
                <div class="text-sm text-slate-400">@Model.KickoffLabel</div>
            </div>

            <div class="space-y-3 rounded-[1.5rem] bg-slate-950/30 p-5">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Away Club</div>
                <a asp-route="club-details" asp-route-id="@Model.AwayTeamId" class="block font-['Oswald'] text-3xl text-white transition hover:text-lime-300">@Model.AwayTeamName</a>
                <div class="font-['Oswald'] text-6xl leading-none text-white">@Model.AwayGoals</div>
            </div>
        </div>
    </section>

    <section class="grid gap-8 xl:grid-cols-2">
        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Match Information</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Context on the fixture</h2>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-1">
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Competition</div>
                    <a asp-route="league-details" asp-route-id="@Model.LeagueId" class="mt-3 block text-lg font-semibold text-lime-300 transition hover:text-lime-200">@Model.LeagueName</a>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Kickoff</div>
                    <strong class="mt-3 block text-lg text-white">@Model.Date.ToString("MMMM dd, yyyy")</strong>
                </article>
                <article class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 sm:col-span-2 xl:col-span-1">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">Status</div>
                    <strong class="mt-3 block text-lg text-white">@Model.StatusLabel</strong>
                </article>
            </div>
        </section>

        <section class="rounded-[1.75rem] border border-white/10 bg-slate-900/80 p-6 shadow-[0_18px_50px_rgba(0,0,0,0.28)] sm:p-7">
            <div class="mb-5">
                <span class="font-['Oswald'] text-sm uppercase tracking-[0.24em] text-lime-400">Related Clubs</span>
                <h2 class="mt-2 font-['Oswald'] text-3xl leading-none text-white">Move deeper into the matchup</h2>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
                <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                    <div>
                        <h3 class="text-xl font-semibold text-white">@Model.HomeTeamName</h3>
                        <p class="mt-1 text-sm text-slate-400">Home club context</p>
                    </div>
                    <div class="mt-4 flex flex-wrap gap-2 text-sm text-slate-300">
                        <span class="rounded-full border border-white/10 px-3 py-1">League: @Model.LeagueName</span>
                        <span class="rounded-full border border-white/10 px-3 py-1">Goals: @Model.HomeGoals</span>
                    </div>
                    <a asp-route="club-details" asp-route-id="@Model.HomeTeamId" class="mt-5 text-sm font-medium text-lime-300 transition hover:text-lime-200">Open home club</a>
                </article>

                <article class="flex h-full flex-col rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition hover:bg-white/10">
                    <div>
                        <h3 class="text-xl font-semibold text-white">@Model.AwayTeamName</h3>
                        <p class="mt-1 text-sm text-slate-400">Away club context</p>
                    </div>
                    <div class="mt-4 flex flex-wrap gap-2 text-sm text-slate-300">
                        <span class="rounded-full border border-white/10 px-3 py-1">League: @Model.LeagueName</span>
                        <span class="rounded-full border border-white/10 px-3 py-1">Goals: @Model.AwayGoals</span>
                    </div>
                    <a asp-route="club-details" asp-route-id="@Model.AwayTeamId" class="mt-5 text-sm font-medium text-lime-300 transition hover:text-lime-200">Open away club</a>
                </article>
            </div>
        </section>
    </section>

    <div>
        <a asp-route="matches-index" class="text-sm font-medium text-lime-300 transition hover:text-lime-200">Back to all matches</a>
    </div>
</section>
